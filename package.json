{
  "name": "mochi-note",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "predev": "node scripts/prepare-supabase-env.mjs",
    "dev": "wxt",
    "predev:firefox": "node scripts/prepare-supabase-env.mjs",
    "dev:firefox": "wxt -b firefox",
    "prebuild": "node scripts/prepare-supabase-env.mjs",
    "build": "wxt build",
    "prebuild:firefox": "node scripts/prepare-supabase-env.mjs",
    "build:firefox": "wxt build -b firefox",
    "lint": "eslint . --max-warnings=0",
    "postinstall": "wxt prepare",
    "prepare:store": "powershell -ExecutionPolicy Bypass -File scripts/prepare-store-assets.ps1",
    "prepare:wxt": "wxt prepare",
    "quality": "eslint . --max-warnings=0 && tsc --noEmit && vitest run && wxt build",
    "supabase:reset": "supabase db reset --local --no-seed",
    "supabase:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-supabase-local.ps1",
    "supabase:setup:test": "powershell -ExecutionPolicy Bypass -File scripts/setup-supabase-local.ps1 -RunTests",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:verify": "node scripts/test-supabase-local.mjs",
    "test": "vitest run",
    "test:e2e": "wxt build && playwright test",
    "verify:release": "powershell -ExecutionPolicy Bypass -File scripts/verify-release.ps1",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prezip": "node scripts/prepare-supabase-env.mjs",
    "zip": "wxt zip"
  },
  "dependencies": {
    "@axe-core/playwright": "4.10.2",
    "@fontsource-variable/nunito": "5.2.7",
    "@playwright/test": "1.55.0",
    "@supabase/supabase-js": "^2.110.7",
    "idb": "8.0.3",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "supabase": "^2.109.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
